---
const { runAt } = Astro.props;

const formattedDate = runAt
  ? new Date(runAt).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
    })
  : null;
---

<section class="relative overflow-hidden pt-24 pb-16 px-4">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,var(--tw-gradient-stops))] from-zinc-700/20 via-zinc-950 to-zinc-950"></div>

  <div class="relative max-w-4xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-zinc-700/50 bg-zinc-800/50 text-sm text-zinc-400 mb-6">
      <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
      Benchmarks running every 5 minutes
    </div>

    <h1 class="text-5xl md:text-6xl font-bold tracking-tight mb-6">
      <span class="bg-linear-to-r from-blue-400 via-cyan-400 to-emerald-400 bg-clip-text text-transparent">.NET Mapper</span>
      <br />Benchmarks
    </h1>

    <p class="text-lg md:text-xl text-zinc-400 max-w-2xl mx-auto mb-8">
      Real-time performance comparison of popular .NET object mapping libraries.
      Automated benchmarks with averaged results from the last 50 runs.
    </p>

    {formattedDate && (
      <p class="text-sm text-zinc-500">
        Last updated: <time class="text-zinc-400">{formattedDate}</time>
      </p>
    )}

    <div class="mt-8 flex justify-center gap-4">
      <a
        href="#benchmarks"
        class="px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white font-medium rounded-lg transition-colors"
      >
        View Results
      </a>
      <a
        href="https://github.com/jagobainda/DotnetMappingBenchmarks"
        target="_blank"
        rel="noopener noreferrer"
        class="px-6 py-3 border border-zinc-700 hover:border-zinc-500 text-zinc-300 font-medium rounded-lg transition-colors"
      >
        GitHub Repository ↗
      </a>
    </div>
  </div>
</section>



