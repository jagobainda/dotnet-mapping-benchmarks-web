---
const features = [
  {
    icon: '⏱',
    title: 'Automated Execution',
    description: 'BenchmarkDotNet benchmarks run automatically every hour on a dedicated VPS.',
  },
  {
    icon: '📊',
    title: 'Averaged Results',
    description: 'Results shown are the average of the full history of the last 3 months, reducing noise and outliers.',
  },
  {
    icon: '🔄',
    title: 'Auto-Updated Libraries',
    description: 'Library versions are updated automatically so benchmarks always reflect the latest releases.',
  },
  {
    icon: '🎯',
    title: 'Multiple Scenarios',
    description: 'Each library is tested across flat mapping, nested objects, collections, and name differences.',
  },
];
---

<section class="py-16 px-4">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-center text-white mb-3">
      How It Works
    </h2>
    <p class="text-center text-zinc-400 mb-12 max-w-2xl mx-auto">
      A transparent and reproducible benchmarking pipeline for .NET object mappers
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {features.map(f => (
        <div class="bg-zinc-900/40 border border-zinc-800 rounded-xl p-6 hover:border-zinc-700 transition-colors">
          <div class="text-2xl mb-3">{f.icon}</div>
          <h3 class="text-white font-semibold mb-2">{f.title}</h3>
          <p class="text-zinc-400 text-sm leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

