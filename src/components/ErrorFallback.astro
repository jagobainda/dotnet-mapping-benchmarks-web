---
interface Props {
  message?: string | null;
}

const { message } = Astro.props;
---

<section class="py-12 px-4">
  <div class="max-w-md mx-auto text-center bg-slate-900/40 border border-slate-800 rounded-xl p-8">
    <div class="text-4xl mb-4">⚠️</div>
    <h2 class="text-xl font-semibold text-white mb-2">Data Unavailable</h2>
    <p class="text-slate-400 text-sm mb-6">
      {message || 'Benchmark data could not be loaded. The server might be temporarily unavailable.'}
    </p>
    <a
      href="/"
      class="inline-block px-5 py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-300 text-sm font-medium rounded-lg transition-colors"
    >
      Try Again
    </a>
  </div>
</section>

