---
interface Props {
  title?: string;
  description?: string;
  jsonLd?: object | object[];
}

const {
  title = '.NET Mapper Benchmarks',
  description = 'Real-time performance comparison of .NET object mapping libraries — AutoMapper, Mapperly, Mapster and more. Benchmarks run every 5 minutes, averaged over 50 runs.',
  jsonLd,
} = Astro.props;

const SITE = 'https://benchmarks.jagoba.dev';
const canonicalURL = new URL(Astro.url.pathname, SITE).href;
const fullTitle = title === '.NET Mapper Benchmarks' ? title : `${title} | .NET Mapper Benchmarks`;

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: '.NET Mapper Benchmarks',
  description,
  url: SITE,
  author: {
    '@type': 'Person',
    name: 'Jagoba',
    url: 'https://github.com/jagobainda',
  },
  inLanguage: 'en',
  isAccessibleForFree: true,
};

const schemas = [websiteSchema, ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])];

import '../styles/global.css';
---

<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content=".NET object mapper, AutoMapper, Mapperly, Mapster, TinyMapper, AgileMapper, benchmark, performance, comparison, C#, dotnet, BenchmarkDotNet" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/')}favicon.svg`} />
    <link rel="icon" href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/')}favicon.ico`} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content=".NET Mapper Benchmarks" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <link rel="alternate" type="text/plain" title="LLM-friendly description" href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/')}llms.txt`} />

    {schemas.map(schema => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body class="bg-zinc-950 text-zinc-100 antialiased min-h-screen">
    <slot />
  </body>
</html>